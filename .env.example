## Base URLs
BASE_URL=https://demoqa.com
API_BASE_URL=https://jsonplaceholder.typicode.com

## DemoQA Credentials
DEMOQA_USERNAME=your_username
DEMOQA_PASSWORD=your_password

## MongoDB (optional — only needed if using MongoService)
# MONGO_URI=mongodb+srv://user:pass@cluster.example.com
# MONGO_DB=my_database

## Elasticsearch (optional — only needed if using ElasticsearchService)
# ELASTICSEARCH_NODE=https://es.example.com:9200
# ELASTICSEARCH_API_KEY=your_api_key
# ELASTICSEARCH_USER=elastic
# ELASTICSEARCH_PASSWORD=your_password
# ELASTICSEARCH_TLS_REJECT_UNAUTHORIZED=false

## SMTP (optional — only needed if using MailService with custom SMTP)
## If not set, MailService.create() falls back to a disposable Ethereal account.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_password
